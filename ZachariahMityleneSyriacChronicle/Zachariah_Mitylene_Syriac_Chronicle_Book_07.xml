            <note xml:id="n186-8">So Cod. Rom. <!--  Add Syriac  -->.</note>
            <note xml:id="n186-9">Jas. i. 2-4.</note>
            <note xml:id="n187-1"><!--  Add Syriac  -->, i.e. ἐξέρκετον, or exercitus.</note>
